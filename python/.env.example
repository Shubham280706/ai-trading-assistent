# Telegram Bot (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Email delivery (optional - uses Gmail SMTP)
EMAIL_ENABLED=false
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@gmail.com

# Output directory for JSON reports
DATA_DIR=./data

# Schedule time (IST = Asia/Kolkata)
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=30

# Vercel deployment — push briefs to database so the live site can read them
# Set NEXT_API_URL to your Vercel URL and NEXT_API_KEY to any secret string
# (must match MARKET_BRIEF_API_KEY env var on Vercel)
NEXT_API_URL=https://your-app.vercel.app
NEXT_API_KEY=your_secret_api_key_here
